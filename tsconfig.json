{
  "files": [],
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@contracts/*": ["./contracts/*"],
      "@db/*": ["./db/*"]
    }
  },
  "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" },
    { "path": "./tsconfig.server.json" }
  ],
  /* 关键点：显式告诉 TS 主项目包含这些后端逻辑文件 */
  "include": [
    "api/**/*.ts",
    "contracts/**/*.ts",
    "db/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
